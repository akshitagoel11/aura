// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id                String  @id @default(cuid())
  email             String  @unique
  name              String?
  googleRefreshToken String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tasks      Task[]
  reminders  Reminder[]
  activities Activity[]
  messages   Message[]
  sessions   Session[]
  scheduledJobs ScheduledJob[]

  @@map("users")
}

model Task {
  id        String   @id @default(cuid())
  userId    String
  title     String
  dueDate   DateTime?
  severity   Severity @default(LOW)
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model Reminder {
  id        String   @id @default(cuid())
  userId    String
  title     String
  eventTime DateTime
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reminders")
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  type        String
  description String
  status      String   @default("completed")
  metadata    String?  // JSON string for additional data
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activities")
}

model Message {
  id        String   @id @default(cuid())
  userId    String
  role      String   // "user" or "assistant"
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model ScheduledJob {
  id            String   @id @default(cuid())
  userId        String
  actionType    String   // email | task | reminder
  payload       String   // JSON string
  scheduledTime DateTime
  status        String   @default("pending") // pending | executed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("scheduled_jobs")
}
